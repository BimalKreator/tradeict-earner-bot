# Copy to .env and adjust. Never commit .env.

# HS256 signing key for user session JWT (min 32 characters). Required on tradeictearner.online.
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Shown on /contact and fallback text on /terms when no terms row exists
SUPPORT_EMAIL=support@tradeictearner.online

# PostgreSQL (required for /api/health/db and Drizzle migrations)
DATABASE_URL=postgresql://user:password@localhost:5432/tradeict_earner

# App timezone for future business logic (IST)
TZ=Asia/Kolkata

# Bearer secret for /api/cron/* (Vercel Cron: set the same value in project env; optional ?secret= for curl)
CRON_SECRET=replace-with-long-random-secret

# Hours after weekly ledger due_at before bot entries are auto-blocked (0 = block when due_at is in the past)
REVENUE_SHARE_BLOCK_GRACE_HOURS=0

# Phase 1 auth: when "true", /user/* skips session checks only — /admin/* still requires a real admin JWT
AUTH_PHASE1_BYPASS=true

# When "true" in production, allows POST /api/auth/stub to set a dev cookie (keep false in real prod)
AUTH_PHASE1_ALLOW_STUB=false

# --- Database seed (npm run db:seed) ---
# Defaults in seed.ts: bimal@tradeictearner.online / Tikhat@999 when these are unset (local dev).
# Override for production; password min 8 characters.
SEED_ADMIN_EMAIL=bimal@tradeictearner.online
SEED_ADMIN_PASSWORD=Tikhat@999
SEED_ADMIN_NAME=Platform Admin
# Production: must set explicitly to allow seeding (rotate/remove after first deploy)
ALLOW_DB_SEED=false

# Phase 8: AES-256-GCM encryption for exchange API ciphertext columns.
# Must be exactly 32 UTF-8 code units and 32 bytes (use ASCII). Not base64 — literal key string.
# Mnemonic for docs: tradeict_super_secret_crypto_32byte — only a 32-char slice is valid, e.g.:
EXCHANGE_SECRETS_ENCRYPTION_KEY=tradeict_super_secret_crypto32by

# Delta India REST base (optional; default https://api.india.delta.exchange)
# DELTA_INDIA_API_BASE_URL=https://api.india.delta.exchange

# Trading engine: when not "true", order placement uses the mock adapter (safe default).
# Live Delta orders need JSON map symbol → numeric product_id (see Delta API /v2/products).
# Example: {"BTCUSD":27,"ETHUSD":28}
# DELTA_INDIA_SYMBOL_TO_PRODUCT_ID={"BTCUSD":27}

DELTA_TRADING_ENABLED=false

# --- Native TA: RSI scalper worker (`npm run trading:ta-worker`) ---
# Fetches OHLCV from Delta public REST and dispatches short signals when rules match.
# TA_RSI_SCALPER_ENABLED=false
# TA_RSI_SCALPER_STRATEGY_ID=
# TA_RSI_SCALPER_QUANTITY=
# Optional: symbol for candles + signal (default BTC_USDT); use BTCUSD + india API if needed
# TA_RSI_SCALPER_SYMBOL=BTC_USDT
# TA_RSI_SCALPER_DELTA_BASE_URL=https://api.delta.exchange
# TA_RSI_SCALPER_RESOLUTION=5m
# TA_RSI_SCALPER_RSI_PERIOD=14
# TA_RSI_SCALPER_RSI_LEVEL=70
# TA_RSI_SCALPER_LOOKBACK_SEC=172800
# TA_RSI_SCALPER_INTERVAL_MS=60000

# --- Transactional email (Nodemailer + SMTP, Phase 4) ---
# Required for registration, login OTP, password reset, and approval/rejection emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use true for port 465 (implicit TLS)
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
# From header (falls back to SMTP_USER if unset)
EMAIL_FROM=noreply@tradeictearner.online
EMAIL_FROM_NAME=Tradeict Earner

# --- Cashfree PG (Phase 11) ---
# Public origin for return_url / notify_url (no trailing slash). On Vercel, set explicitly in prod.
# NEXT_PUBLIC_APP_URL=https://tradeictearner.online

# Outbound IP of this server (VPS/NAT) — shown on /user/exchange for Delta API key IP whitelisting.
# If unset, users see "IP not configured". Rebuild/redeploy after changing NEXT_PUBLIC_* vars.
# NEXT_PUBLIC_SERVER_OUTBOUND_IP=203.0.113.50
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
# Webhook HMAC secret (Cashfree dashboard; falls back to CASHFREE_CLIENT_SECRET if unset)
CASHFREE_SECRET_KEY=
# sandbox | production — controls API host and Drop-in mode
CASHFREE_ENV=sandbox
